# Firebase (production — შეავსე Firebase Console-ის მონაცემებით)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# სურვილისამებრ (Analytics)
# VITE_FIREBASE_MEASUREMENT_ID=

# false = ნამდვილი Firebase; true = ლოკალური emulator (npm run dev:all)
VITE_USE_FIREBASE_EMULATOR=false

# საწყისი მენეჯერის ემაილები (რეგისტრაციისას ავტომატურად manager როლს მიიღებენ)
# VITE_BOOTSTRAP_MANAGER_EMAILS=admin@gmail.com
